  "data_model_reference": {
    "subdomains": ["geospatial", "regulation_graph", "operator_catalog", "user_session"],
    "core_entities": {
      "geospatial": ["RoadSegment", "ParkingArea", "Zone", "PointOfInterest"],
      "regulation_graph": ["Regulation", "Rule", "TimeWindow", "AppliesTo", "HolidayCalendar"],
      "operator_catalog": ["Operator", "OperatorZone", "Tariff", "Permit"],
      "user_session": ["Vehicle", "ParkingSession", "RuleEvaluation", "FineEvent", "Notification"]
    },
    "design_principles": [
      "Provenance on every regulation (source_id, source_ref, effective_from/to)",
      "Day-types as first-class concept (HolidayCalendar per country/region)",
      "RuleEvaluation cached with next-change-timestamp for sub-100ms geofence query",
      "AppliesTo with offset_from/to for n-metre rules (10m, 20m, 30m)",
      "Loose coupling between Zone (city-defined) and OperatorZone (provider-internal)"
    ]
  },

  "extension_targets_priority": [
