# Copy to .env.local for development.
# Anything prefixed with VITE_ is bundled into the client; do not put secrets here.

# Backend API base URL.
# Dev: http://localhost:8080
# Prod: https://api.parkingfree.io (or whatever you deploy)
VITE_API_BASE_URL=http://localhost:8080

# Google Maps JavaScript API key.
# Get one at: https://console.cloud.google.com/google/maps-apis/credentials
# Restrict it to your domain(s) in production.
VITE_GOOGLE_MAPS_API_KEY=

# Optional: backend API key sent in X-API-Key header on /allowed requests.
# Leave blank if the backend is running with no auth (CORS-only).
VITE_API_KEY=

# Optional: base path for the built site.
# Default "/" is correct for custom domains, Cloudflare Pages, Vercel,
# Netlify, and GitHub Pages with a custom domain.
# For project-page GitHub Pages (e.g. /parking-free/), set:
# VITE_BASE_PATH=/parking-free/
VITE_BASE_PATH=/
