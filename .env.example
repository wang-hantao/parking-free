# HTTP server
HTTP_ADDR=:8080
HTTP_READ_TIMEOUT=10s
HTTP_WRITE_TIMEOUT=15s

# CORS — comma-separated list of browser origins allowed to call the API
# cross-origin. Empty disables CORS (correct when there are no browser
# clients, or the frontend is served from the same origin).
# For local development with the React dev server:
#   CORS_ALLOWED_ORIGINS=http://localhost:5173
# In production, list each frontend origin explicitly:
#   CORS_ALLOWED_ORIGINS=https://parkingfree.io,https://www.parkingfree.io
CORS_ALLOWED_ORIGINS=

# Postgres (matches docker-compose.yml defaults)
PG_DSN=postgres://parking:parking@localhost:5432/parking?sslmode=disable

# Logging
LOG_LEVEL=info
LOG_FORMAT=json

# Stockholm LTF-Tolken
# Request a free key at https://openparking.stockholm.se/Home/Key
STOCKHOLM_API_KEY=
STOCKHOLM_API_BASE=https://openparking.stockholm.se/LTF-Tolken/v1

# Ingester
INGEST_TIMEOUT=2m
